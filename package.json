{
  "name": "global-bird-knowledge-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "python scripts/build_knowledge_json.py",
    "build:data:fast": "python scripts/build_knowledge_json.py --skip-raw-summaries",
    "rebuild:preview": "python scripts/rebuild_summary_preview.py",
    "build:search-index": "python scripts/build_lightweight_index.py",
    "fetch:bird-images": "python scripts/fetch_bird_images.py",
    "crawl:wikipedia": "python scripts/crawl_from_wikipedia.py",
    "fetch:taxonomy": "python scripts/fetch_taxonomy.py",
    "download:bird-names": "python scripts/download_bird_name_list.py",
    "neo4j:up": "docker compose -f docker-compose.neo4j.yml up -d",
    "neo4j:down": "docker compose -f docker-compose.neo4j.yml down",
    "import:neo4j": "python scripts/import_to_neo4j.py",
    "dev:api": "node server/neo4j-api.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "build:embeddings": "python scripts/build_embeddings.py",
    "build:graph-embeddings": "python scripts/build_graph_embeddings.py",
    "build:location-chunks": "python scripts/build_location_chunks.py",
    "search:server": "python scripts/search_server.py"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.3.0",
    "3d-force-graph": "^1.80.0",
    "d3": "^7.9.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.10.0",
    "graphology": "^0.26.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "sigma": "^2.4.0",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
