axonomy-phylum-chordata", "class": "taxonomy-class-aves", "order": "taxonomy-order-procellariiformes", "family": "taxonomy-family-procellariidae", "genus": "taxonomy-genus-puffinus", "species": "taxonomy-species-puffinus-opisthomelas"}, "expandable": true, "x": -333.18, "y": -739.54, "z": -84.45}, {"id": "taxonomy-species-puffinus-opisthomelas", "name": "Black-vented shearwater", "latinName": "Puffinus opisthomelas", "type": "taxonomy", "taxonomyLevel": "species", "summary": "Black-vented shearwater（Puffinus opisthomelas）是图谱中的分类级分类节点，当前关联1种鸟类，如Black-vented shearwater。", "expandable": true, "memberCount": 1, "x": -333.18, "y": -739.54, "z": -101.28}, {"id": "taxonomy-genus-puffinus", "name": "剪水鹱属", "latinName": "Puffinus", "type": "taxonomy", "taxonomyLevel": "genus", "summary": "剪水鹱属（Puffinus）是图谱中的分类级分类节点，当前关联19种鸟类，如Christmas shearwater、Galápagos shearwater、Fluttering shearwater等19种鸟类。", "expandable": true, "memberCount": 19, "x": -544.54, "y": 410.8, "z": 16.62}], "links": [{"key": "bird-black-vented-shearwater-ec4da4e2__belongs_to_species__taxonomy-species-puffinus-opisthomelas", "source": "bird-black-vented-shearwater-ec4da4e2", "target": "taxonomy-species-puffinus-opisthomelas", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-puffinus-opisthomelas__belongs_to_genus__taxonomy-genus-puffinus", "source": "taxonomy-species-puffinus-opisthomelas", "target": "taxonomy-genus-puffinus", "relation": "belongs_to_genus", "label": "属于属", "evidence": "依据 birds.csv 分类字段补充：Black-vented shearwater 属于属 剪水鹱属。"}]}
