{"meta": {"centerNodeId": "taxonomy-species-basileuterus-melanogenys", "centerNodeType": "taxonomy", "generatedAt": "2026-05-28T16:28:22", "includedNodeCount": 3, "includedLinkCount": 2, "layoutMode": "precomputed-static"}, "center": {"id": "taxonomy-species-basileuterus-melanogenys", "name": "Black-cheeked warbler", "type": "taxonomy"}, "nodes": [{"id": "bird-black-cheeked-warbler-b395cf90", "name": "Black-cheeked warbler", "englishName": "Black-cheeked warbler", "latinName": "Basileuterus melanogenys", "type": "bird", "status": "LC", "summary": "The black-cheeked warbler (Basileuterus melanogenys) is a New World warbler, resident breeding bird endemic to the Talamancan montane forests of Costa Rica and western Panama. It is normally found in oak forests with a dense bamboo understory from 2500 m altitude to the timberline, but occasionally occurs as low as 1600 m. The breeding pair builds a bulky domed nest with a side entrance on a sloping bank or in a gully, and the female lays two white eggs. The black-cheeked warbler is 13–13.5 cm long and weighs 13 g. It has a rufous crown, long white supercilia and black cheeks. The upperparts are dull olive, the breast is olive-grey, and the belly is yellow-white. The sexes are similar, but the young bird is browner on the upperparts, has a dull supercilium, a greyer breast, and shows two cinnamon wingbars. Despite this species' restricted range, it has three subspecies. B. m. melanogenys, the nominate race described above, breeds in central and southern Costa Rica. B. m. eximius is highly localised in a small area of western Panama, and is slightly whiter on the belly than melanogenys. B. m. bensoni is highly localised in a small area of west-central Panama, and is whiter below than eximius, and a purer grey above. The black-cheeked warbler primarily feeds on insects, spiders and other small invertebrates, taken low in the undergrowth. The call note of the black-cheeked warbler is a hard tsit, and the male's song is a lisping spluttered tsi tsi wee tsi tsi wu tsi wee. References Curson, Quinn and Beadle,New World Warblers ISBN 978-0-7136-3932-2 Stiles and Skutch, A guide to the birds of Costa Rica ISBN 978-0-8014-9600-4", "shortSummary": "The black-cheeked warbler (Basileuterus melanogenys) is a New World warbler, resident breeding bird endemic to the Talamancan montane fores…", "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Basileuterus_melanogenys_269755085.jpg/960px-Basileuterus_melanogenys_269755085.jpg", "kingdomId": "taxonomy-kingdom-animalia", "phylumId": "taxonomy-phylum-chordata", "classId": "taxonomy-class-aves", "genusId": "taxonomy-genus-basileuterus", "speciesId": "taxonomy-species-basileuterus-melanogenys", "taxonomyIds": {"kingdom": "taxonomy-kingdom-animalia", "phylum": "taxonomy-phylum-chordata", "class": "taxonomy-class-aves", "genus": "taxonomy-genus-basileuterus", "species": "taxonomy-species-basileuterus-melanogenys"}, "expandable": true, "x": 450.75, "y": 187.86, "z": 173.89}, {"id": "taxonomy-genus-basileuterus", "name": "Basileuterus", "latinName": "Basileuterus", "type": "taxonomy", "taxonomyLevel": "genus", "summary": "Basileuterus（Basileuterus）是图谱中的分类级分类节点，当前关联11种鸟类，如Fan-tailed warbler、Rufous-capped warbler、Black-cheeked warbler等11种鸟类。", "expandable": true, "memberCount": 11, "x": 52.43, "y": 413.38, "z": 58.98}, {"id": "taxonomy-species-basileuterus-melanogenys", "name": "Black-cheeked warbler", "latinName": "Basileuterus melanogenys", "type": "taxonomy", "taxonomyLevel": "species", "summary": "Black-cheeked warbler（Basileuterus melanogenys）是图谱中的分类级分类节点，当前关联1种鸟类，如Black-cheeked warbler。", "expandable": true, "memberCount": 1, "x": 450.75, "y": 187.86, "z": 190.68}], "links": [{"key": "bird-black-cheeked-warbler-b395cf90__belongs_to_species__taxonomy-species-basileuterus-melanogenys", "source": "bird-black-cheeked-warbler-b395cf90", "target": "taxonomy-species-basileuterus-melanogenys", "relation": "belongs_to_species", "label": "属于种"