my-genus-heliactin", "species": "taxonomy-species-heliactin-bilophus"}, "expandable": true, "x": 17.54, "y": 905.09, "z": 44.97}, {"id": "taxonomy-species-heliactin-bilophus", "name": "角蜂鸟", "latinName": "Heliactin bilophus", "type": "taxonomy", "taxonomyLevel": "species", "summary": "角蜂鸟（Heliactin bilophus）是图谱中的分类级分类节点，当前关联1种鸟类，如角蜂鸟。", "expandable": true, "memberCount": 1, "x": 17.54, "y": 905.09, "z": 54.22}], "links": [{"key": "bird-角蜂鸟-edff1ae7__belongs_to_species__taxonomy-species-heliactin-bilophus", "source": "bird-角蜂鸟-edff1ae7", "target": "taxonomy-species-heliactin-bilophus", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-heliactin-bilophus__belongs_to_genus__taxonomy-genus-heliactin", "source": "taxonomy-species-heliactin-bilophus", "target": "taxonomy-genus-heliactin", "relation": "belongs_to_genus", "label": "属于属", "evidence": "依据 birds.csv 分类字段补充：角蜂鸟 属于属 Heliactin。"}]}
