{"meta": {"centerNodeId": "taxonomy-species-poecile-hyrcanus", "centerNodeType": "taxonomy", "generatedAt": "2026-05-28T16:28:22", "includedNodeCount": 3, "includedLinkCount": 2, "layoutMode": "precomputed-static"}, "center": {"id": "taxonomy-species-poecile-hyrcanus", "name": "Caspian tit", "type": "taxonomy"}, "nodes": [{"id": "bird-caspian-tit-dbf60829", "name": "Caspian tit", "englishName": "Caspian tit", "latinName": "Poecile hyrcanus", "type": "bird", "status": "LC", "summary": "The Caspian tit (Poecile hyrcanus) is a passerine bird in the tit family. It breeds in the deciduous mountain forests with its core population concentrated in the Hyrcanian forests of Iran, just extending into Azerbaijan. It is considered one of the most range-restricted tit species. The 12.5 cm (4.9 in) long Caspian tit has a dark brown cap and bib, rich brown upperparts and underparts which are pinkish-buff when fresh, but become paler and greyer as the feathers age. The sexes are similar, but juveniles are somewhat duller. The most common call of this generally quiet bird is a thin zsit, but a nasal double note, chev chev, is also given. Both sexes excavate the nesting hole in a live or a rotten tree. Most nests examined are cups of felted material, such as fur, hair and wood chips, but feathers are sometimes used. The number of eggs varies from five to seven, white with faint reddish spots or blotches. It feeds on caterpillars, insects and seeds, much like other tits. Molecular phylogenetic studies have shown that the Caspian tit is sister to the willow tit (Poecile montanus). References Harrap, S., & Quinn, D. (1996). Tits, Nuthatches and Treecreepers. Christopher Helm. ISBN 0-7136-3964-4", "shortSummary": "The Caspian tit (Poecile hyrcanus) is a passerine bird in the tit family. It breeds in the deciduous mountain forests with its core populat…", "locations": ["希爾卡尼亞森林", "伊朗", "阿塞拜疆"], "habitats": ["山地森林"], "lat": 32.0, "lng": 53.0, "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/1/15/Poecile_hyrcanus_351030492.jpg/960px-Poecile_hyrcanus_351030492.jpg", "kingdomId": "taxonomy-kingdom-animalia", "phylumId": "taxonomy-phylum-chordata", "classId": "taxonomy-class-aves", "genusId": "taxonomy-genus-poecile", "speciesId": "taxonomy-species-poecile-hyrcanus", "taxonomyIds": {"kingdom": "taxonomy-kingdom-animalia", "phylum": "taxonomy-phylum-chordata", "class": "taxonomy-class-aves", "genus": "taxonomy-genus-poecile", "species": "taxonomy-species-poecile-hyrcanus"}, "expandable": true, "x": 146.69, "y": 50.25, "z": -293.02}, {"id": "taxonomy-species-poecile-hyrcanus", "name": "Caspian tit", "latinName": "Poecile hyrcanus", "type": "taxonomy", "taxonomyLevel": "species", "summary": "Caspian tit（Poecile hyrcanus）是图谱中的分类级分类节点，当前关联1种鸟类，如Caspian tit。", "expandable": true, "memberCount": 1, "x": 146.69, "y": 50.25, "z": -275.74}, {"id": "taxonomy-genus-poecile", "name": "Poecile", "latinName": "Poecile", "type": "taxonomy", "taxonomyLevel": "genus", "summary": "Poecile（Poecile）是图谱中的分类级分类节点，当前关联15种鸟类，如白眉山雀、Sombre tit、红腹山雀等15种鸟类。", "expandable": true, "memberCount": 15, "x": -252.65, "y": -538.09, "z": -36.94}], "links": [{"key": "bird-caspian-tit-dbf60829__belongs_to_species__taxonomy-species-poecile-hyrcanus", "source": "bird-caspian-tit-dbf60829", "target": "taxonomy-species-poecile-hyrcanus", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-poecile-hyrcanus__belongs_to_genus__taxonomy-genus-poecile", "source": "taxonomy-species-poecile-hyrcanus", "target": "taxonomy-genus-poecile", "relation": "belongs_to_genus", "label": "属于属", "evidence": "依据 birds.csv 分类字段补充：Caspian tit 属于属 Poecile。"}]}
