{"meta": {"centerNodeId": "taxonomy-species-chrysocorythus-estherae", "centerNodeType": "taxonomy", "generatedAt": "2026-05-28T16:28:22", "includedNodeCount": 3, "includedLinkCount": 2, "layoutMode": "precomputed-static"}, "center": {"id": "taxonomy-species-chrysocorythus-estherae", "name": "Indonesian serin", "type": "taxonomy"}, "nodes": [{"id": "bird-indonesian-serin-ab69c027", "name": "Indonesian serin", "englishName": "Indonesian serin", "latinName": "Chrysocorythus estherae", "type": "bird", "status": "LC", "summary": "The Indonesian serin (Chrysocorythus estherae) is a species of finch in the family Fringillidae. It is found in Indonesia. Its natural habitats are subtropical or tropical moist montane forest and subtropical or tropical high-altitude grassland. The Indonesian serin was formerly placed in the genus Serinus but a phylogenetic analysis of mitochondrial DNA sequences found that the species was not closely related to other member of Serinus nor to the geographically nearest finch, the Vietnamese greenfinch but to the European Goldfinch Carduelis carduelis and to the Citril Finch Carduelis citrinella. The species was therefore assigned to a separate genus Chrysocorythus, a name that had previously been proposed by the German ornithologist Hans Edmund Wolters in 1967. The Mindanao serin (C. mindanensis) of Mindanao was formerly considered conspecific, together called the mountain serin, but was split as a distinct species by the IOC in 2021. The Indonesian serin is polytypic with four subspecies, including the nominate subspecies of western Java. The other races include: Chrysocorythus estherae vanderbilti (Meyer de Schauensee, 1939) (including Serinus estherae ripleyi Chasen, 1939). Sumatra. Chrysocorythus estherae orientalis (Chasen, 1940) (including the replacement name Serinus estherae chaseni). Tengger range, eastern Java. Chrysocorythus estherae renatae (Schuchmann & Wolters, 1982). Mount Rantekombola, Sulawesi. There are also outstanding records of an unusual taxon of this species in Lore Lindu National Park, northern Central Sulawesi. References", "shortSummary": "The Indonesian serin (Chrysocorythus estherae) is a species of finch in the family Fringillidae. It is found in Indonesia.", "lat": -5.0, "lng": 120.0, "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/5/51/Chrysocorythus_estherae_2.jpg", "kingdomId": "taxonomy-kingdom-animalia", "phylumId": "taxonomy-phylum-chordata", "classId": "taxonomy-class-aves", "genusId": "taxonomy-genus-chrysocorythus", "speciesId": "taxonomy-species-chrysocorythus-estherae", "taxonomyIds": {"kingdom": "taxonomy-kingdom-animalia", "phylum": "taxonomy-phylum-chordata", "class": "taxonomy-class-aves", "genus": "taxonomy-genus-chrysocorythus", "species": "taxonomy-species-chrysocorythus-estherae"}, "expandable": true, "x": -84.96, "y": 75.81, "z": 35.64}, {"id": "taxonomy-species-chrysocorythus-estherae", "name": "Indonesian serin", "latinName": "Chrysocorythus estherae", "type": "taxonomy", "taxonomyLevel": "species", "summary": "Indonesian serin（Chrysocorythus estherae）是图谱中的分类级分类节点，当前关联1种鸟类，如Indonesian serin。", "expandable": true, "memberCount": 1, "x": -84.96, "y": 75.81, "z": 41.85}, {"id": "taxonomy-genus-chrysocorythus", "name": "Chrysocorythus", "latinName": "Chrysocorythus", "type": "taxonomy", "taxonomyLevel": "genus", "summary": "Chrysocorythus（Chrysocorythus）是图谱中的分类级分类节点，当前关联2种鸟类，如Mindanao serin、Indonesian serin。", "expandable": true, "memberCount": 2, "x": 556.63, "y": 23.84, "z": 39.48}], "links": [{"key": "bird-indonesian-serin-ab69c027__belongs_to_species__taxonomy-species-chrysocorythus-estherae", "source": "bird-indonesian-serin-ab69c027", "target": "taxonomy-species-chrysocorythus-estherae", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-chrysocorythus-estherae__belongs_to_genus__taxonomy-genus-chrysocorythus", "source": "taxonomy-species-chrysocorythus-estherae", "target": "tax