nn-s-gull-f2ac98bc__belongs_to_species__taxonomy-species-larus-heermanni", "source": "bird-heermann-s-gull-f2ac98bc", "target": "taxonomy-species-larus-heermanni", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-larus-heermanni__belongs_to_genus__taxonomy-genus-larus", "source": "taxonomy-species-larus-heermanni", "target": "taxonomy-genus-larus", "relation": "belongs_to_genus", "label": "属于属", "evidence": "依据 birds.csv 分类字段补充：Heermann's gull 属于属 鸥属。"}]}
