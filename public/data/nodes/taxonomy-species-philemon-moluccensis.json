ific with the Tanimbar friarbird (Philemon plumigenis) with the common name \"black-faced friarbird\". The Buru friarbird is more similar in appearance to the Seram friarbird (Philemon subcorniculatus) than it is to the Tanimbar friarbird. References", "shortSummary": "The Buru friarbird or black-faced friarbird (Philemon moluccensis) is a species of bird in the family Meliphagidae. It is endemic to the is…", "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/0/06/Philemon_moluccensis_-_James_Eaton_-_416865988_%28cropped%29.jpeg/960px-Philemon_moluccensis_-_James_Eaton_-_416865988_%28cropped%29.jpeg", "kingdomId": "taxonomy-kingdom-animalia", "phylumId": "taxonomy-phylum-chordata", "classId": "taxonomy-class-aves", "genusId": "taxonomy-genus-philemon", "speciesId": "taxonomy-species-philemon-moluccensis", "taxonomyIds": {"kingdom": "taxonomy-kingdom-animalia", "phylum": "taxonomy-phylum-chordata", "class": "taxonomy-class-aves", "genus": "taxonomy-genus-philemon", "species": "taxonomy-species-philemon-moluccensis"}, "expandable": true, "x": 1094.94, "y": -71.66, "z": -383.46}, {"id": "taxonomy-genus-philemon", "name": "Philemon", "latinName": "Philemon", "type": "taxonomy", "taxonomyLevel": "genus", "summary": "Philemon（Philemon）是图谱中的分类级分类节点，当前关联16种鸟类，如小吮蜜鳥、Meyer's friarbird、Timor friarbird等16种鸟类。", "expandable": true, "memberCount": 16, "x": 561.35, "y": 18.3, "z": -26.17}], "links": [{"key": "bird-buru-friarbird-5d65cef2__belongs_to_species__taxonomy-species-philemon-moluccensis", "source": "bird-buru-friarbird-5d65cef2", "target": "taxonomy-species-philemon-moluccensis", "relation": "belongs_to_species", "label": "属于种", "evidence": "依据 birds.csv 中的种字段补充。"}, {"key": "taxonomy-species-philemon-moluccensis__belongs_to_genus__taxonomy-genus-philemon", "source": "taxonomy-species-philemon-moluccensis", "target": "taxonomy-genus-philemon", "relation": "belongs_to_genus", "label": "属于属", "evidence": "依据 birds.csv 分类字段补充：Buru friarbird 属于属 Philemon。"}]}
